// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ComponentType {
  BILTONG_BULK
  PACKAGING
}

/// How a Shopify product relates to production planning.
enum SkuClassification {
  FINISHED_PRODUCT      // has a recipe; drives production planning
  BUNDLE                // maps to multiple finished products
  RAW_COMPONENT_SOLD    // sold directly; also tracked as a Component
  PACKAGING_ITEM        // tracked but no production recipe
  IGNORED               // exclude from all planning views
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  REORDER_DUE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum StockMovementType {
  RECEIPT
  SALE
  ADJUSTMENT
}

enum PackedStockMovementType {
  PACK
  SALE
  ADJUSTMENT
}

/// Shopify product synced via syncShopifyCatalog().
model ShopifyProduct {
  id                String           @id @default(uuid())
  shopifyProductGid String           @unique
  title             String
  handle            String
  status            String
  syncedAt          DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  variants          ShopifyVariant[]

  @@index([shopifyProductGid])
}

/// Shopify variant synced via syncShopifyCatalog(). Linked to a ShopifyProduct.
model ShopifyVariant {
  id                      String         @id @default(uuid())
  shopifyVariantGid       String         @unique
  shopifyProductGid       String
  title                   String
  sku                     String?
  price                   String
  inventoryItemGid        String?
  /// Shopify inventoryQuantity at last sync. Null if inventory tracking is off for this variant.
  inventoryQuantity       Int?
  syncedAt                DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  product                 ShopifyProduct @relation(fields: [shopifyProductGid], references: [shopifyProductGid], onDelete: Cascade)

  @@index([shopifyProductGid])
  @@index([sku])
}

/// Inventory alert — created by alertService.evaluateAlerts() when stock drops below reorderPoint.
model Alert {
  id             String        @id @default(uuid())
  type           AlertType
  severity       AlertSeverity
  componentId    String?
  sellableSkuId  String?
  currentLevel   Float
  reorderPoint   Float
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())
  component      Component?    @relation(fields: [componentId], references: [id], onDelete: SetNull)
  sellableSku    SellableSKU?  @relation(fields: [sellableSkuId], references: [id], onDelete: SetNull)

  @@index([resolvedAt])
  @@index([componentId])
  @@index([sellableSkuId])
}

model Component {
  id                String              @id @default(uuid())
  name              String
  type              ComponentType
  unit              String
  reorderPoint      Float
  reorderQty        Float
  createdAt         DateTime            @default(now())
  skuComponentRules SKUComponentRule[]
  stockMovements    StockMovement[]
  receiptLines      ReceiptLine[]
  alerts            Alert[]
}

model Receipt {
  id           String        @id @default(uuid())
  supplierName String
  invoiceRef   String?
  receivedAt   DateTime
  note         String?
  createdAt    DateTime      @default(now())
  lines        ReceiptLine[]

  @@index([receivedAt])
}

model ReceiptLine {
  id             String          @id @default(uuid())
  receiptId      String
  componentId    String
  quantity       Float
  unitCost       Float?
  receipt        Receipt         @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  component      Component       @relation(fields: [componentId], references: [id], onDelete: Restrict)
  stockMovements StockMovement[]

  @@index([receiptId])
  @@index([componentId])
}

model Supplier {
  id           String  @id @default(uuid())
  name         String
  email        String?
  leadTimeDays Int?
}

/// User-defined product category — created on the Products page and assigned
/// to any SellableSKU. Examples: "Ready to Sell", "Component", "Merch".
model ProductCategory {
  id        String        @id @default(uuid())
  name      String        @unique
  createdAt DateTime      @default(now())
  skus      SellableSKU[]
}

model SellableSKU {
  id                 String                 @id @default(uuid())
  name               String
  sku                String                 @unique
  isBundle           Boolean                @default(false)
  /// How this product relates to production planning. Null = unclassified.
  classification     SkuClassification?
  /// Optional user-defined category. Null = uncategorised.
  categoryId         String?
  category           ProductCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt          DateTime               @default(now())
  skuComponentRules  SKUComponentRule[]
  bundleAsParent     BundleComponent[]      @relation("BundleParent")
  bundleAsChild      BundleComponent[]      @relation("BundleChild")
  manualSaleLines      ManualSaleLine[]
  packedStockMovements PackedStockMovement[]
  shopifyVariantMapping ShopifyVariantMapping?
  alerts               Alert[]

  @@index([categoryId])
}

/// Links an internal sellable SKU to Shopify Admin API resources (variant + optional inventory item GIDs).
model ShopifyVariantMapping {
  id                      String      @id @default(uuid())
  sellableSkuId           String      @unique
  shopifyVariantGid       String
  shopifyInventoryItemGid String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  sellableSku             SellableSKU @relation(fields: [sellableSkuId], references: [id], onDelete: Cascade)

  @@index([shopifyVariantGid])
}

model ManualSale {
  id                   String                 @id @default(uuid())
  orderRef             String?
  createdAt            DateTime               @default(now())
  lines                ManualSaleLine[]
  stockMovements       StockMovement[]
  packedStockMovements PackedStockMovement[]

  @@index([createdAt])
  @@index([orderRef])
}

model ManualSaleLine {
  id                  String               @id @default(uuid())
  manualSaleId        String
  sellableSkuId       String
  quantity            Float
  manualSale          ManualSale           @relation(fields: [manualSaleId], references: [id], onDelete: Cascade)
  sku                 SellableSKU          @relation(fields: [sellableSkuId], references: [id], onDelete: Restrict)
  packedStockMovement PackedStockMovement?
  stockMovements      StockMovement[]

  @@index([manualSaleId])
  @@index([sellableSkuId])
}

model SKUComponentRule {
  id          String      @id @default(uuid())
  skuId       String
  componentId String
  qtyPerUnit  Float
  sku         SellableSKU @relation(fields: [skuId], references: [id], onDelete: Cascade)
  component   Component   @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([skuId, componentId])
  @@index([skuId])
  @@index([componentId])
}

model PackingRun {
  id                 String                 @id @default(uuid())
  createdAt          DateTime               @default(now())
  note               String?
  componentMovements StockMovement[]
  packedMovements    PackedStockMovement[]
}

model PackedStockMovement {
  id                String                  @id @default(uuid())
  sellableSkuId     String
  qtyChange         Float
  type              PackedStockMovementType
  sourceType        String
  createdAt         DateTime                @default(now())
  note              String?
  manualSaleId      String?
  /// Idempotency key: at most one SALE movement per ManualSaleLine.
  /// Nullable so PACK and ADJUSTMENT rows are unaffected.
  manualSaleLineId  String?                 @unique
  packingRunId      String?
  sellableSku       SellableSKU             @relation(fields: [sellableSkuId], references: [id], onDelete: Restrict)
  manualSale        ManualSale?             @relation(fields: [manualSaleId], references: [id], onDelete: SetNull)
  manualSaleLine    ManualSaleLine?         @relation(fields: [manualSaleLineId], references: [id], onDelete: SetNull)
  packingRun        PackingRun?             @relation(fields: [packingRunId], references: [id], onDelete: SetNull)

  @@index([sellableSkuId])
  @@index([createdAt])
  @@index([manualSaleId])
  @@index([packingRunId])
}

model BundleComponent {
  id           String      @id @default(uuid())
  parentSkuId  String
  childSkuId   String
  qty          Int
  parentSku    SellableSKU @relation("BundleParent", fields: [parentSkuId], references: [id], onDelete: Cascade)
  childSku     SellableSKU @relation("BundleChild", fields: [childSkuId], references: [id], onDelete: Cascade)

  @@index([parentSkuId])
  @@index([childSkuId])
}

model StockMovement {
  id               String             @id @default(uuid())
  componentId      String
  type             StockMovementType
  qtyChange        Float
  sourceType       String
  note             String?
  createdAt        DateTime           @default(now())
  manualSaleId     String?
  /// Idempotency key for sale-driven deductions.
  /// Composite unique with componentId ensures one deduction per (line, component).
  /// Nullable so RECEIPT and ADJUSTMENT rows are unaffected.
  manualSaleLineId String?
  receiptLineId    String?
  packingRunId     String?
  component        Component          @relation(fields: [componentId], references: [id], onDelete: Cascade)
  manualSale       ManualSale?        @relation(fields: [manualSaleId], references: [id], onDelete: SetNull)
  manualSaleLine   ManualSaleLine?    @relation(fields: [manualSaleLineId], references: [id], onDelete: SetNull)
  receiptLine      ReceiptLine?       @relation(fields: [receiptLineId], references: [id], onDelete: SetNull)
  packingRun       PackingRun?        @relation(fields: [packingRunId], references: [id], onDelete: SetNull)

  @@unique([manualSaleLineId, componentId])
  @@index([componentId])
  @@index([createdAt])
  @@index([manualSaleId])
  @@index([receiptLineId])
  @@index([packingRunId])
}
