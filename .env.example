# Supabase: use Connect → Session pooler (or Transaction), NOT "Direct" — Vercel needs IPv4-friendly pooler.
# See EASY-DEPLOY.md. Required on Vercel: Project → Environment Variables → DATABASE_URL → Production + Preview.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Shopify (Custom app / single store) — optional until you connect ---
# Admin API: create a custom app in Shopify Admin → Settings → Apps → Develop apps
# SHOPIFY_SHOP_DOMAIN="your-store.myshopify.com"
# SHOPIFY_ADMIN_ACCESS_TOKEN="shpat_..."
# SHOPIFY_API_VERSION="2025-01"
