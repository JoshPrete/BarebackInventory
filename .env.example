# Supabase → Settings → Database → Connection string (pooler, port 5432)
# Required locally and on Vercel (Project → Settings → Environment Variables) for build + runtime.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"

# --- Shopify (Custom app / single store) — optional until you connect ---
# Admin API: create a custom app in Shopify Admin → Settings → Apps → Develop apps
# SHOPIFY_SHOP_DOMAIN="your-store.myshopify.com"
# SHOPIFY_ADMIN_ACCESS_TOKEN="shpat_..."
# SHOPIFY_API_VERSION="2025-01"
